# KonstanceAI Environment Configuration
# Copy this file to .env and fill in your values

# Required: Telegram Bot Token
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Optional: OpenClaw Relay (for AI replies)
# If you have OpenClaw running locally, set this
OPENCLAW_CMD=python openclaw_relay.py
OPENCLAW_CWD=C:\Users\Thinkpad\Desktop\KonstanceAI\openclaw
OPENCLAW_RELAY_URL=ws://127.0.0.1:18789
OWNER_ID=8158300788

# Optional: local LLM model selector (qwen2.5, phi-mini, or hf:<model-id>)
LOCAL_LLM_MODEL=qwen2.5
OLLAMA_MODEL=qwen2.5:3b
